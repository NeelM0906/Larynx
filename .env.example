# ----------------------------------------------------------------------------
# Larynx environment configuration
# Copy to `.env` and edit. All LARYNX_* vars are read by pydantic-settings.
# ----------------------------------------------------------------------------

# API bearer token for /v1/* endpoints. Rotate quarterly. Required.
LARYNX_API_TOKEN=change-me-please

# TTS worker mode:
#   mock   = deterministic sine-wave generator. No GPU needed. Use for scaffold
#            verification, CI, and smoke tests on dev boxes without VoxCPM2.
#   voxcpm = load real nano-vllm-voxcpm on GPU 0. Required for production.
LARYNX_TTS_MODE=mock

# Default sample rate (Hz) when the client doesn't pass one.
LARYNX_DEFAULT_SAMPLE_RATE=24000

# GPU id for the VoxCPM2 worker (ignored in mock mode).
LARYNX_VOXCPM_GPU=0

# Postgres connection (matches docker-compose.yml, non-default port 5433).
DATABASE_URL=postgresql+psycopg://larynx:larynx@localhost:5433/larynx

# Redis connection (matches docker-compose.yml, non-default port 6380).
REDIS_URL=redis://localhost:6380/0

# Logging
LARYNX_LOG_LEVEL=INFO
LARYNX_LOG_JSON=true

# Gateway bind
LARYNX_HOST=0.0.0.0
LARYNX_PORT=8000
